# KIVU Backend Configuration
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/kivu

# Authentication
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# AI Services (for translation, speech, tutoring)
OPENAI_API_KEY=sk-...
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# File uploads
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads
