# ─── KIVU Backend — variables d'environnement ────────────────
#
# Copie ce fichier en .env (sans le .example) et remplis les valeurs.
# Le fichier .env est dans .gitignore — il ne sera pas commité.

# ─── IA Assistant Kivi (au moins UNE clé pour Kivi puissant) ─
#
# OPTION 1 — ANTHROPIC (Claude Sonnet 4.5) — RECOMMANDÉ pour KIVU
# Excellente qualité multilingue, idéal pour les langues africaines.
# Récupère ta clé : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OPTION 2 — OPENAI (gpt-4o)
# Bonne qualité, voix TTS premium incluse via le même fournisseur.
# Récupère ta clé : https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Si les deux sont définies, KIVU utilise Anthropic en priorité.
# Si AUCUNE n'est définie, le frontend utilise sa knowledge base
# offline (100+ sujets africains) — l'app fonctionne quand même.

# ─── Voix premium IA (synthèse vocale neurale) ───────────────
# OPTIONNEL — pour voix humaines réalistes (vs Web Speech API)
#
# ELEVENLABS (multilingual_v2) — meilleure qualité africaine
# Voice cloning, accents authentiques. https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Override des voice IDs ElevenLabs par langue (optionnel) :
# ELEVENLABS_VOICE_SWA=<voice-id-swahili>
# ELEVENLABS_VOICE_WOL=<voice-id-wolof>

# ─── Base de données (défaut SQLite local) ──────────────────
DATABASE_URL=sqlite:///kivu.db

# ─── CORS — frontend autorisé ────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://kivu.vercel.app

# ─── Sécurité (CHANGE EN PROD !) ─────────────────────────────
SECRET_KEY=change-me-in-production-please
JWT_SECRET=change-me-too-in-production
JWT_EXPIRATION_DAYS=30

# ─── Serveur ────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=1
